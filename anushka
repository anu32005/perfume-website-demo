  h.classList.remove('active');
  void h.offsetWidth;
  h.classList.add('active');
  setTimeout(() => h.classList.remove('active'), 1500);
}

function showPetals() {
  const c = document.getElementById('petalContainer');
  c.innerHTML = ''; c.classList.add('active');
  const colors = ['#f8bbd9','#c8e6c9','#fff9c4','#ffccbc','#e1bee7','#f48fb1','#a5d6a7','#ffecb3'];
  for (let i = 0; i < 60; i++) {
    const p = document.createElement('div');
    p.className = 'petal';
    const size = 12 + Math.random()*16;
    p.style.cssText = left:${Math.random()*100}%;top:${-20-Math.random()*60}px;background:${colors[Math.floor(Math.random()*colors.length)]};width:${size}px;height:${size+4}px;border-radius:${Math.random()>.5?'50% 0 50% 0':'0 50% 0 50%'};animation-duration:${2+Math.random()*2.5}s;animation-delay:${Math.random()*.9}s;;
    c.appendChild(p);
  }
  setTimeout(() => { c.classList.remove('active'); c.innerHTML=''; }, 4500);
}

renderProducts('all');
</script>

